# Production-like deployment template.
# Copy to .env.production and replace every CHANGE_ME value before deployment.
#
# If a value contains '$', escape it as '$$' to avoid Docker Compose
# interpolation warnings.

POSTGRES_PASSWORD=CHANGE_ME_STRONG_DATABASE_PASSWORD
EDC_API_AUTH_KEY=CHANGE_ME_LONG_RANDOM_MANAGEMENT_KEY

# Private service token used by local-assets and download-sink.
# This value is also used as the HMAC signing key for per-file download tokens.
# Never expose it as a browser-visible or public value.
LOCAL_ASSETS_AUTH_TOKEN=CHANGE_ME_LONG_RANDOM_LOCAL_ASSETS_TOKEN

# Optional per-connector local-assets API keys for services that aggregate
# both production connectors. Leave empty to reuse LOCAL_ASSETS_AUTH_TOKEN.
UC3M_LOCAL_ASSETS_AUTH_TOKEN=
FUENLABRADA_LOCAL_ASSETS_AUTH_TOKEN=

# ArcGIS Enterprise login gate.
# Set ARCGIS_AUTH_ENABLED=false for deployments that do not require ArcGIS login.
ARCGIS_AUTH_ENABLED=true
ARCGIS_PORTAL_URL=https://your-arcgis-enterprise.example.org/arcgis
ARCGIS_CLIENT_ID=CHANGE_ME_ARCGIS_CLIENT_ID
ARCGIS_REQUIRED_ORG_ID=
ARCGIS_REQUIRED_GROUP_ID=

# Optional group identifiers used by the institutional UC3M/Fuenlabrada profiles.
ARCGIS_UC3M_GROUP_ID=
ARCGIS_FUENLA_GROUP_ID=

# Optional email notifications.
# Leave CAAS_SMTP_HOST empty to disable outgoing email.
CAAS_SMTP_HOST=
CAAS_SMTP_PORT=587
CAAS_SMTP_USER=
CAAS_SMTP_PASSWORD=
CAAS_SMTP_FROM=TOPIC Connector <no-reply@example.org>
CAAS_SMTP_USE_TLS=true
