# Copy to .env.production and set secure values.
# If a value contains '$', escape it as '$$' to avoid compose interpolation warnings.
POSTGRES_PASSWORD=CHANGE_ME_STRONG
EDC_API_AUTH_KEY=CHANGE_ME_LONG_RANDOM

# Optional: ArcGIS Enterprise login gate for the UI
# ArcGIS login is enabled by default for production.
ARCGIS_AUTH_ENABLED=true
ARCGIS_PORTAL_URL=https://gis.eiteldata.eu/arcgis
ARCGIS_CLIENT_ID=
ARCGIS_REDIRECT_URI=https://gis.eiteldata.eu/conectoruc3m/
ARCGIS_REQUIRED_ORG_ID=
ARCGIS_REQUIRED_GROUP_ID=
