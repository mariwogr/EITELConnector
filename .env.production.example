# Copy to .env.production and set secure values.
# If a value contains '$', escape it as '$$' to avoid compose interpolation warnings.
POSTGRES_PASSWORD=CHANGE_ME_STRONG
EDC_API_AUTH_KEY=CHANGE_ME_LONG_RANDOM

# Private service token for local-assets/download-sink.
# Do not expose this as NEXT_PUBLIC_* in production; browser access is validated
# with the ArcGIS user token and EDC/internal Docker calls stay on the private network.
LOCAL_ASSETS_AUTH_TOKEN=CHANGE_ME_LONG_RANDOM_LOCAL_ASSETS

# Optional: ArcGIS Enterprise login gate for the UI
# ArcGIS login is enabled by default for production.
ARCGIS_AUTH_ENABLED=true
ARCGIS_PORTAL_URL=https://gis.eiteldata.eu/arcgis
ARCGIS_CLIENT_ID=
ARCGIS_REDIRECT_URI=https://gis.eiteldata.eu/conectoruc3m/
ARCGIS_REQUIRED_ORG_ID=
ARCGIS_REQUIRED_GROUP_ID=
ARCGIS_UC3M_GROUP_ID=
ARCGIS_FUENLA_GROUP_ID=

# ---------------------------------------------------------------------------
# SMTP — Notificaciones automáticas (solicitudes de acceso y decisiones)
# ---------------------------------------------------------------------------
# Deja CAAS_SMTP_HOST vacío para deshabilitar todos los correos.
# Credenciales compartidas por ambos conectores (uc3m y Fuenlabrada).
#
# Ejemplo con Gmail (App Password de Google):
#   CAAS_SMTP_HOST=smtp.gmail.com
#   CAAS_SMTP_PORT=587
#   CAAS_SMTP_USER=no-reply@eiteldata.eu
#   CAAS_SMTP_PASSWORD=xxxx-xxxx-xxxx-xxxx
#   CAAS_SMTP_FROM=EITEL Connector <no-reply@eiteldata.eu>
#   CAAS_SMTP_USE_TLS=true
CAAS_SMTP_HOST=
CAAS_SMTP_PORT=587
CAAS_SMTP_USER=
CAAS_SMTP_PASSWORD=
CAAS_SMTP_FROM=EITEL Connector <no-reply@eiteldata.eu>
CAAS_SMTP_USE_TLS=true
