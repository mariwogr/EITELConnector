CAAS_BASE_DOMAIN=gis.eiteldata.eu
CAAS_PATH_PREFIX_TEMPLATE=/conector{tenant}
CAAS_DEFAULT_EDC_API_KEY=change-me
CAAS_DEFAULT_DB_PASSWORD=change-me
# PERFIL ACTIVO: opción B (build desde Git).
CAAS_EDC_CONNECTOR_SOURCE=git
CAAS_EDC_CONNECTOR_IMAGE=eitel/eclipse-edc-runtime:0.16.0

# BLOQUE GIT-FORK (activar cuando SOURCE=git)
# Recomendación: usar un fork/repo runtime wrapper con Dockerfile de despliegue.
# No usar el repo base eclipse-edc/Connector con Dockerfile="Dockerfile" si no existe un runtime deployable.
CAAS_EDC_CONNECTOR_GIT_URL=https://github.com/mariwogr/EITELConnector.git
CAAS_EDC_CONNECTOR_GIT_REF=578ab995a83739d0ec8eb9553822fd0ce49722ce
# Debe apuntar a un Dockerfile REAL dentro del repo Git configurado (o de tu fork/runtime wrapper).
CAAS_EDC_CONNECTOR_GIT_DOCKERFILE=deploy/Dockerfile

# Si el repo es privado, usa URL con credenciales (PAT clásico o fine-grained con permisos de lectura):
# CAAS_EDC_CONNECTOR_GIT_URL=https://<github-user>:<github-token>@github.com/mariwogr/EITELConnector.git

# Ejemplo completo:
# CAAS_EDC_CONNECTOR_GIT_URL=https://github.com/eiteldata/connector-runtime.git
# CAAS_EDC_CONNECTOR_GIT_REF=v0.16.0
# CAAS_EDC_CONNECTOR_GIT_DOCKERFILE=deploy/Dockerfile
CAAS_EDC_UI_IMAGE=eitel/edc-ui:latest
CAAS_SQLITE_URL=sqlite:///./data/caas.db
CAAS_GENERATED_OUTPUT_DIR=./data/generated

# Seguridad de local-assets. En produccion, los accesos de navegador se
# validan contra ArcGIS Enterprise; el token privado queda para servicio/dev
# y no debe publicarse como NEXT_PUBLIC_*.
CAAS_LOCAL_ASSETS_AUTH_REQUIRED=true
CAAS_LOCAL_ASSETS_AUTH_TOKEN=CHANGE_ME_LONG_RANDOM_LOCAL_ASSETS
CAAS_LOCAL_ASSETS_ALLOW_INTERNAL_UNAUTHENTICATED=true
CAAS_ARCGIS_AUTH_ENABLED=true
CAAS_ARCGIS_PORTAL_URL=https://gis.eiteldata.eu/arcgis
CAAS_ARCGIS_REQUIRED_ORG_ID=
CAAS_ARCGIS_REQUIRED_GROUP_ID=

# ---------------------------------------------------------------------------
# SMTP — Notificaciones automáticas de solicitudes de acceso (no-reply EITEL)
# ---------------------------------------------------------------------------
# Deja CAAS_SMTP_HOST vacío para deshabilitar completamente las notificaciones.
#
# Ejemplo con Gmail (App Password):
#   CAAS_SMTP_HOST=smtp.gmail.com
#   CAAS_SMTP_PORT=587
#   CAAS_SMTP_USER=no-reply@eiteldata.eu
#   CAAS_SMTP_PASSWORD=xxxx-xxxx-xxxx-xxxx   # App Password de Google
#   CAAS_SMTP_FROM="EITEL Connector <no-reply@eiteldata.eu>"
#   CAAS_SMTP_USE_TLS=true
#
# Ejemplo con Outlook / Office 365:
#   CAAS_SMTP_HOST=smtp.office365.com
#   CAAS_SMTP_PORT=587
#   CAAS_SMTP_USER=no-reply@eiteldata.eu
#   CAAS_SMTP_PASSWORD=tu-contraseña
#   CAAS_SMTP_FROM="EITEL Connector <no-reply@eiteldata.eu>"
#   CAAS_SMTP_USE_TLS=true
#
# Ejemplo con servidor SMTP propio sin TLS (puerto 25 o 2525):
#   CAAS_SMTP_HOST=mail.eiteldata.eu
#   CAAS_SMTP_PORT=25
#   CAAS_SMTP_USER=
#   CAAS_SMTP_PASSWORD=
#   CAAS_SMTP_FROM=no-reply@eiteldata.eu
#   CAAS_SMTP_USE_TLS=false

CAAS_SMTP_HOST=
CAAS_SMTP_PORT=587
CAAS_SMTP_USER=
CAAS_SMTP_PASSWORD=
CAAS_SMTP_FROM=EITEL Connector <no-reply@eiteldata.eu>
CAAS_SMTP_USE_TLS=true

# URL pública del conector (se incluye como enlace en los correos).
# Ejemplo: https://gis.eiteldata.eu/conectoruc3m/edc-ui
CAAS_CONNECTOR_PUBLIC_URL=https://gis.eiteldata.eu/conectoruc3m/edc-ui
