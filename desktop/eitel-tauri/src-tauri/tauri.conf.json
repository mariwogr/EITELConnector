{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "EITEL Connector Desktop",
  "version": "0.1.0",
  "identifier": "eu.eiteldata.connector.desktop",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://127.0.0.1:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "EITEL Connector Desktop",
        "width": 1120,
        "height": 760,
        "minWidth": 900,
        "minHeight": 620,
        "resizable": true,
        "fullscreen": false
      }
    ],
    "security": {
      "csp": "default-src 'self'; style-src 'self' 'unsafe-inline'; img-src 'self' data:; connect-src 'self' https://gis.eiteldata.eu http://localhost:* http://127.0.0.1:*; frame-src https://gis.eiteldata.eu http://localhost:* http://127.0.0.1:*;"
    }
  },
  "bundle": {
    "active": true,
    "targets": ["nsis", "msi"],
    "publisher": "EITEL",
    "category": "Business"
  }
}
